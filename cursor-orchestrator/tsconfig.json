{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@state": ["./src/state/index.ts"],
      "@state/*": ["./src/state/*"]
    }
  },
  "include": ["src/**/*", "extension.ts"],
  "exclude": ["node_modules", "dist", "webview"]
}
